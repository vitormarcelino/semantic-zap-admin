// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id           // Clerk user ID (e.g. "user_2abc...")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agents       Agent[]
  subscription Subscription?
  invoices     Invoice[]
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])

  plan                  String    @default("trial")   // "trial" | "starter" | "pro" | "business"
  status                String    @default("trial")
  // Status values:
  // "trial"            — within 30-day trial period
  // "trial_ended"      — trial expired, not yet subscribed
  // "active"           — paid subscription active
  // "past_due"         — payment failed, within 5-day grace period
  // "blocked"          — grace period expired or trial ended, features locked
  // "cancelled"        — user cancelled, access ended
  // "cancelled_active" — cancelled but still within paid period
  billingCycle          String?   // "monthly" | "yearly"

  trialStartedAt        DateTime  @default(now())
  trialEndsAt           DateTime

  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean   @default(false)
  cancelledAt           DateTime?

  pastDueAt             DateTime?
  gracePeriodEndsAt     DateTime?

  asaasCustomerId       String?   @unique
  asaasSubscriptionId   String?   @unique

  messagesUsedThisMonth Int       @default(0)
  usagePeriodStart      DateTime  @default(now())

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Invoice {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id])

  asaasPaymentId      String    @unique
  asaasSubscriptionId String?

  amount              Float
  status              String    // "pending" | "paid" | "overdue" | "cancelled" | "refunded"
  billingType         String    // "CREDIT_CARD" | "BOLETO" | "PIX"
  dueDate             DateTime
  paidAt              DateTime?
  invoiceUrl          String?
  bankSlipUrl         String?
  pixQrCode           String?
  pixCopiaECola       String?
  description         String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
}

model Agent {
  id          String   @id @default("")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @default("")
  description String?
  language    String   @default("pt-BR")
  tone        String   @default("amigavel")
  model       String   @default("gpt-4o")
  temperature Float    @default(0.7)
  maxTokens      Int      @default(300)
  phoneNumber    String?
  provider       String?
  whatsappPhoneNumberId String?
  whatsappAccessToken   String?
  twilioAccountSid      String?
  twilioAuthToken       String?
  telegramBotToken      String?
  systemPrompt   String?
  greetingPrompt String?
  fallbackPrompt String?
  conversations  Conversation[]
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Conversation {
  id            String    @id @default(cuid())
  agentId       String
  phoneNumber   String
  status        String    @default("active")
  lastMessageAt DateTime  @default(now())
  mode          String    @default("bot")   // "bot" | "human"
  assignedTo    String?                      // operator display name or ID
  unreadCount   Int       @default(0)        // user messages without operator reply (human mode only)
  messages      Message[]
  agent         Agent     @relation(fields: [agentId], references: [id])

  @@unique([agentId, phoneNumber])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // "user" | "assistant"
  content        String
  status         String       @default("pending") // pending | processing | sent | failed
  wamid          String?      @unique              // WhatsApp message ID or Twilio SmsSid — used for deduplication
  sentBy         String?                           // "bot" | "operator:{userId}" | null for user messages
  deliveredAt    DateTime?                         // set when Meta delivery webhook fires (WhatsApp only)
  readAt         DateTime?                         // set when Meta read receipt webhook fires (WhatsApp only)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([createdAt])
  @@index([conversationId, createdAt])
}